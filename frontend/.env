# API Configuration
VITE_API_URL=http://localhost:3000

# WebRTC Configuration (TURN/STUN Servers)
# STUN server (free, public)
VITE_STUN_URL=stun:stun.l.google.com:19302

# TURN server (required for production)
# Option 1: Free service from Metered.ca (https://www.metered.ca/tools/openrelay/)
VITE_TURN_URL=turn:a.relay.metered.ca:80
VITE_TURN_USER=your-metered-username
VITE_TURN_CRED=your-metered-credential

# Option 2: Google's STUN servers (backup)
# VITE_STUN_URL_2=stun:stun1.l.google.com:19302
# VITE_STUN_URL_3=stun:stun2.l.google.com:19302
