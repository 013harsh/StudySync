# API Configuration
VITE_API_URL=http://localhost:3000

# WebRTC Configuration (TURN/STUN Servers)
# STUN server (free, public) - helps discover your public IP
VITE_STUN_URL=stun:stun.l.google.com:19302

# TURN server (required for production) - relays traffic when direct connection fails
# Get free credentials from: https://www.metered.ca/tools/openrelay/
VITE_TURN_URL=turn:a.relay.metered.ca:80
VITE_TURN_USER=your-metered-username
VITE_TURN_CRED=your-metered-credential

# Alternative TURN servers:
# - Metered.ca: https://www.metered.ca/tools/openrelay/ (Free tier available)
# - Twilio: https://www.twilio.com/stun-turn (Paid)
# - Xirsys: https://xirsys.com/ (Free tier available)
# - Self-hosted: coturn (https://github.com/coturn/coturn)
